generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String            @id @default(cuid())
  name                     String?
  email                    String            @unique
  passwordHash             String?
  age                      Int?
  image                    String?
  emailVerified            DateTime?
  role                     String            @default("RUNNER")
  subscriptionTier         String            @default("FREE")
  stripeCustomerId         String?           @unique
  stripeSubscriptionId     String?           @unique
  stripeSubscriptionStatus String?
  accounts                 Account[]
  sessions                 Session[]
  stravaAccount            StravaAccount?
  activities               Activity[]
  blogComments             BlogComment[]
  trainingPlan             UserTrainingPlan?
  coachedTeams             Team[]            @relation("CoachTeams")
  teamMemberships          TeamMember[]
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StravaAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  athleteId    String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  lastSyncedAt DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([athleteId])
}

model Activity {
  id               String   @id @default(cuid())
  stravaId         String   @unique
  userId           String
  name             String
  type             String
  distance         Float
  movingTime       Int
  elapsedTime      Int
  averageSpeed     Float?
  averageHeartrate Float?
  maxHeartrate     Float?
  startDate        DateTime
  startLat         Float?
  startLng         Float?
  routeKey         String?
  polyline         String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@index([userId, routeKey])
  @@index([userId, startDate])
}

model BlogComment {
  id         String   @id @default(cuid())
  postSlug   String
  authorName String
  content    String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([postSlug, createdAt])
}

model UserTrainingPlan {
  id                String    @id @default(cuid())
  userId            String    @unique
  planId            String
  currentWeek       Int       @default(1)
  restDay           Int       @default(7)
  longRunDay        Int       @default(6)
  runDaysPerWeek    Int       @default(3)
  completedIds      String    @default("[]")
  streak            Int       @default(0)
  lastCompletedDate DateTime?
  startedAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  inviteCode  String       @unique @default(cuid())
  coachId     String
  coach       User         @relation("CoachTeams", fields: [coachId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([coachId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  status    String   @default("PENDING")
  message   String?
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId, status])
}
