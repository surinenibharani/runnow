{
  "name": "letsrunnow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "stripe:setup": "node scripts/stripe-setup.mjs",
    "strava:webhook": "node scripts/strava-webhook-setup.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint src/app/about src/app/contact src/app/faq src/app/tools src/app/start src/lib/tools src/components/tools src/app/stories/page.tsx",
    "gear:update": "node scripts/update-gear-from-rss.mjs",
    "gear:refresh-suggestions": "node scripts/refresh-gear-suggestions.mjs",
    "gear:validate": "node scripts/validate-gear-catalog.mjs",
    "validate:links": "node scripts/validate-content-links.mjs",
    "content:copy-check": "node scripts/content-copy-check-phrases.mjs",
    "test": "tsx --test src/lib/tools/*.test.ts src/lib/blog/publish-schedule.test.ts src/components/blog/format-blog-text.test.ts",
    "strava:encrypt-tokens": "node scripts/encrypt-strava-tokens.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "^5.22.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "stripe": "^22.2.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^5.22.0",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "tsx": "^4.20.3"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
